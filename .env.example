# ==============================================================================
# Empório da Música — variáveis de ambiente (copiar para ".env" e preencher)
# ==============================================================================

# --- Gemini API (Google AI) -------------------------------------------------
GOOGLE_API_KEY=

# Modelo Gemini usado pelo agente. 
GEMINI_MODEL=gemini-2.5-flash

# Máximo de tokens de saída por resposta do agente 
GEMINI_MAX_OUTPUT_TOKENS=1024

# Modelo Gemini usado para gerar embeddings (RAG). Outras opções disponíveis:
# gemini-embedding-2, gemini-embedding-2-preview.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Dimensão solicitada dos vetores de embedding (via `output_dimensionality`).
GEMINI_EMBEDDING_DIM=768

# --- Aplicação -------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# --- Dados (consulta a dados tabulares) ------------------------------------
DATA_DIR=./data
POLICIES_PDF_PATH=./data/políticas.pdf

# --- RAG ------------------------------------------------------------
VECTOR_STORE_PATH=./storage/vector_store

# --- Histórico de conversas -----------------------------------------
CONVERSATION_HISTORY_PATH=./storage/conversation_history
